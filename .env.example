# HeavySwarm Investment Due Diligence Engine - Environment Configuration

# =============================================================================
# API Configuration
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
LOG_LEVEL=INFO
ENVIRONMENT=development

# =============================================================================
# Security
# =============================================================================
SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# =============================================================================
# Database Configuration
# =============================================================================
# PostgreSQL
DATABASE_URL=postgresql+asyncpg://diligence:diligence@localhost:5432/diligence
DB_HOST=localhost
DB_PORT=5432
DB_NAME=diligence
DB_USER=diligence
DB_PASSWORD=diligence

# =============================================================================
# Cache Configuration
# =============================================================================
# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Cache TTLs (in seconds)
CACHE_TTL_SHORT=300
CACHE_TTL_MEDIUM=3600
CACHE_TTL_LONG=86400

# =============================================================================
# LLM API Keys
# =============================================================================
OPENAI_API_KEY=sk-your-openai-api-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
XAI_API_KEY=xai-your-xai-api-key

# LLM Configuration
DEFAULT_MODEL=claude-3-5-sonnet-20241022
FALLBACK_MODEL=gpt-4o

# Grok-specific settings
# grok-4.20-reasoning: Best for complex reasoning tasks (strategist, verifier)
# grok-4.3: Balanced performance for general tasks
# grok-2: Fast and cost-effective for simpler tasks
GROK_DEFAULT_MODEL=grok-4.3
MAX_CONCURRENT_LLM_CALLS=10
LLM_TIMEOUT_SECONDS=60

# =============================================================================
# External Data Sources
# =============================================================================
# Financial Data
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key
BLOOMBERG_API_KEY=your-bloomberg-key
BLOOMBERG_API_URL=https://api.bloomberg.com/v1

# SEC EDGAR
SEC_USER_AGENT=HeavySwarm Engine contact@heavyswarm.io

# News APIs
NEWSAPI_KEY=your-newsapi-key

# =============================================================================
# Trading System Integration
# =============================================================================
TRADING_WEBHOOK_SECRET=your-webhook-secret
TRADING_WEBHOOK_URL=https://your-trading-system.com/webhook

# =============================================================================
# Quality & Performance
# =============================================================================
CONFIDENCE_THRESHOLD=0.85
RISK_SCORE_THRESHOLD=70
MAX_POSITION_SIZE_PCT=0.05
QUALITY_GATE_ENABLED=true

# Performance
MAX_CONCURRENT_DILIGENCES=10
DEFAULT_DILIGENCE_TIMEOUT_SECONDS=300

# =============================================================================
# Monitoring
# =============================================================================
ENABLE_METRICS=true
METRICS_PORT=9090
TRACING_ENABLED=true

# Sentry (optional)
SENTRY_DSN=

# =============================================================================
# Feature Flags
# =============================================================================
ENABLE_QUALITY_GUARDIAN=true
ENABLE_PARALLEL_EXECUTION=true
ENABLE_CIRCUIT_BREAKER=true
ENABLE_CACHE=true
