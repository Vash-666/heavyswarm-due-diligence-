# HeavySwarm Investment Due Diligence Engine - Production Environment Configuration
# =============================================================================
# WARNING: This file contains production secrets. Keep it secure!
# =============================================================================

# =============================================================================
# API Configuration
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
LOG_LEVEL=INFO
ENVIRONMENT=production

# =============================================================================
# Security (Generate strong secrets for production)
# =============================================================================
SECRET_KEY=prod-secret-key-replace-with-256-bit-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# =============================================================================
# Database Configuration (Production PostgreSQL)
# =============================================================================
# PostgreSQL - Use strong credentials in production
DATABASE_URL=postgresql+asyncpg://diligence_prod:CHANGE_THIS_STRONG_PASSWORD@db:5432/diligence_prod
DB_HOST=db
DB_PORT=5432
DB_NAME=diligence_prod
DB_USER=diligence_prod
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# =============================================================================
# Cache Configuration (Production Redis)
# =============================================================================
# Redis - Enable AUTH in production
REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD

# Cache TTLs (in seconds)
CACHE_TTL_SHORT=300
CACHE_TTL_MEDIUM=3600
CACHE_TTL_LONG=86400

# =============================================================================
# LLM API Keys (Production)
# =============================================================================
OPENAI_API_KEY=${OPENAI_API_KEY}
ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY}
XAI_API_KEY=${XAI_API_KEY}

# LLM Configuration
DEFAULT_MODEL=claude-3-5-sonnet-20241022
FALLBACK_MODEL=gpt-4o

# Grok-specific settings
GROK_DEFAULT_MODEL=grok-4.3
MAX_CONCURRENT_LLM_CALLS=10
LLM_TIMEOUT_SECONDS=60

# =============================================================================
# External Data Sources (Production)
# =============================================================================
# Financial Data
ALPHA_VANTAGE_API_KEY=${ALPHA_VANTAGE_API_KEY}
BLOOMBERG_API_KEY=${BLOOMBERG_API_KEY}
BLOOMBERG_API_URL=https://api.bloomberg.com/v1

# SEC EDGAR
SEC_USER_AGENT=HeavySwarm Production Engine contact@heavyswarm.io

# News APIs
NEWSAPI_KEY=${NEWSAPI_KEY}

# =============================================================================
# Trading System Integration (Production)
# =============================================================================
TRADING_WEBHOOK_SECRET=${TRADING_WEBHOOK_SECRET}
TRADING_WEBHOOK_URL=${TRADING_WEBHOOK_URL}

# =============================================================================
# Quality & Performance
# =============================================================================
CONFIDENCE_THRESHOLD=0.85
RISK_SCORE_THRESHOLD=70
MAX_POSITION_SIZE_PCT=0.05
QUALITY_GATE_ENABLED=true

# Performance
MAX_CONCURRENT_DILIGENCES=10
DEFAULT_DILIGENCE_TIMEOUT_SECONDS=300

# =============================================================================
# Monitoring (Production)
# =============================================================================
ENABLE_METRICS=true
METRICS_PORT=9090
TRACING_ENABLED=true

# Sentry (Recommended for production)
SENTRY_DSN=${SENTRY_DSN}

# =============================================================================
# Feature Flags
# =============================================================================
ENABLE_QUALITY_GUARDIAN=true
ENABLE_PARALLEL_EXECUTION=true
ENABLE_CIRCUIT_BREAKER=true
ENABLE_CACHE=true
